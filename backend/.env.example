# Environment Variables
NODE_ENV=development
PORT=8000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecom_db
DB_USER=root
DB_PASS=your_password_here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this-in-production
JWT_REFRESH_EXPIRE=90d

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Email Configuration (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Upload Configuration
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5000000

# Stripe Configuration (for future payment integration)
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# OpenRouter AI Configuration
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:5001
OPENROUTER_APP_NAME=ElegantShop Backend
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=700
AI_CHATBOT_ALLOWED_TABLES=products,categories,product_images,orders

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Bcrypt Rounds
BCRYPT_ROUNDS=12

# Session Secret
SESSION_SECRET=your-session-secret-key-change-this-in-production
